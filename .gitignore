# Local environment override (copied from example)
library/layer/container/agent-tools.env

# macOS metadata
.DS_Store

# Claude Code per-machine settings (project-wide settings.json is fine to commit)
.claude/
opencode.json

# Python bytecode caches from `uv run --script` of repo helpers (slop_tui.py etc.)
scripts/_py/__pycache__/
**/__pycache__/

# Per-repo orchestrator state (slop.cue → .slop/state.json + compile/)
.slop/

# Slop-isolate compile outputs (when run with default --out)
library/.generated/

# Go build artifacts (the safeslop binary lives in cmd/safeslop; built to ./safeslop or ./dist)
/safeslop
/dist/
*.test
*.out
