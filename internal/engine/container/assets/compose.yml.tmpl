services:
  proxy:
    image: ubuntu/squid:5.2-22.04_beta
    volumes:
      - {{.RuntimeDir}}/squid.conf:/etc/squid/squid.conf:ro
      - {{.RuntimeDir}}/allowlist.domains:/etc/squid/allowlist.domains:ro
    networks: [internal, egress]
  agent:
    image: local/agent-sandbox-tools:latest
    working_dir: /workspace
    entrypoint: ["/bin/sh", "/safeslop/runtime/entrypoint.sh"]
    environment:
      HTTP_PROXY: http://proxy:3128
      HTTPS_PROXY: http://proxy:3128
      NO_PROXY: localhost,127.0.0.1,proxy
{{if .NpmConfig}}      NPM_CONFIG_USERCONFIG: /safeslop/runtime/.npmrc
{{end}}{{if .Kubeconfig}}      KUBECONFIG: /safeslop/runtime/kubeconfig
{{end}}{{if .SshKey}}      GIT_SSH_COMMAND: ssh -i /safeslop/runtime/.ssh/id -o IdentitiesOnly=yes -o IdentityAgent=none -o StrictHostKeyChecking=yes -o UserKnownHostsFile=/safeslop/runtime/.ssh/known_hosts
{{end}}{{if .Term}}      TERM: {{.Term}}
{{end}}    volumes:
      - {{.Workspace}}:/workspace:rw
      - {{.StageDir}}:/safeslop/runtime:ro
    read_only: true
    tmpfs:
      - /tmp
      - /var/tmp
    cap_drop: [ALL]
    security_opt:
      - "no-new-privileges:true"
    # internal-only by default: the squid proxy is the ONLY egress, so the allowlist is
    # enforced and there is no direct DNS/route (deny tier). In open-egress mode the agent
    # also joins the egress bridge so it has a real route + working DNS (ping, ssh, direct
    # resolution) — "network: allow" means actually-open, not just HTTP(S)-via-proxy.
    networks: [internal{{if .OpenEgress}}, egress{{end}}]
networks:
  internal:
    internal: true
  egress:
    driver: bridge
