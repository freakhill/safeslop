services:
  proxy:
    image: {{yaml .ProxyImage}}
    user: "13:13"
    read_only: true
    cap_drop: [ALL]
    security_opt:
      - "no-new-privileges:true"
    pids_limit: 128
    tmpfs:
      - "/run:rw,nosuid,nodev,noexec,size=16m,uid=13,gid=13,mode=0750"
      - "/var/log/squid:rw,nosuid,nodev,noexec,size=16m,uid=13,gid=13,mode=0750"
      - "/var/spool/squid:rw,nosuid,nodev,noexec,size=16m,uid=13,gid=13,mode=0750"
    labels:
{{if .SessionID}}      safeslop.session: {{yaml .SessionID}}
{{end}}{{if .InvocationID}}      safeslop.invocation: {{yaml .InvocationID}}
{{end}}      safeslop.managed: "true"
{{if .EgressHash}}      safeslop.egress-revision: "{{.EgressRevision}}"
      safeslop.egress-hash: {{yaml .EgressHash}}
{{end}}    volumes:
{{range .ProxyMounts}}      - type: bind
        source: {{yaml .Source}}
        target: {{yaml .Target}}
        read_only: {{.ReadOnly}}
        bind:
          create_host_path: false
{{end}}    networks: [internal, egress]
  agent:
    image: {{yaml .AgentImage}}
    labels:
{{if .SessionID}}      safeslop.session: {{yaml .SessionID}}
{{end}}{{if .InvocationID}}      safeslop.invocation: {{yaml .InvocationID}}
{{end}}      safeslop.managed: "true"
    working_dir: /workspace
    # Dockerfile.agent already uses USER 1000; hard-set the launch user too so
    # future image drift cannot run the agent as root or mismatch the tmpfs home.
    user: "1000:1000"
    entrypoint: ["/bin/sh", "/safeslop/runtime/entrypoint.sh"]
    environment:
      HTTP_PROXY: http://proxy:3128
      HTTPS_PROXY: http://proxy:3128
      NO_PROXY: localhost,127.0.0.1,proxy
{{if .NpmConfig}}      NPM_CONFIG_USERCONFIG: /safeslop/runtime/.npmrc
{{end}}{{if .Kubeconfig}}      KUBECONFIG: /safeslop/runtime/kubeconfig
{{end}}{{if .GitConfig}}      GIT_CONFIG_GLOBAL: {{yaml .GitConfigPath}}
      GIT_TERMINAL_PROMPT: 0
{{end}}{{if .GitSSHConfig}}      GIT_SSH_COMMAND: ssh -F /safeslop/runtime/.ssh/config.container
{{end}}      TERM: xterm-256color
      COLORTERM: truecolor
{{if not .OpenEgress}}    # Docker keeps 127.0.0.11 for service names, but forwards non-service
    # DNS to this per-container server; loopback makes deny-tier external DNS fail locally.
    dns:
      - 127.0.0.1
{{end}}    volumes:
{{range .AgentMounts}}      - type: bind
        source: {{yaml .Source}}
        target: {{yaml .Target}}
        read_only: {{.ReadOnly}}
        bind:
          create_host_path: false
{{end}}    read_only: true
    tmpfs:
      - /tmp
      - /var/tmp
      # Writable, EPHEMERAL home (specs/0064): agents keep runtime state under
      # $HOME (pi's ~/.pi session store, claude's ~/.claude), which the
      # read-only rootfs refuses — pi exits 1 at startup without it. tmpfs is
      # in-memory and wiped on exit; no host path is exposed. It masks the
      # image's baked shell dotfiles (acceptable: agents, not login shells).
      # uid/gid/mode: a bare tmpfs mounts root:root 0755, which only moves the
      # startup crash from ENOENT to EACCES (validated 2026-07-02) — own it to
      # the agent user (uid 1000 in Dockerfile.agent, matching the hardcoded
      # /home/agent path this template already relies on).
      - /home/agent:uid=1000,gid=1000,mode=0700
    cap_drop: [ALL]
    security_opt:
      - "no-new-privileges:true"
    # internal-only by default: the squid proxy is the ONLY egress, so the allowlist is
    # enforced, external DNS is loopback-pinned, and there is no direct route (deny tier).
    # In open-egress mode the agent also joins the egress bridge so it has a real route +
    # working DNS — "network: allow" means actually-open, not HTTP(S)-via-proxy only.
    networks: [internal{{if .OpenEgress}}, egress{{end}}]
networks:
  internal:
{{if .InternalNet}}    # Pre-created out of band with the engine's `network create --internal`.
    external: true
    name: {{yaml .InternalNet}}
{{else}}    internal: true
    labels:
{{if .SessionID}}      safeslop.session: {{yaml .SessionID}}
{{end}}{{if .InvocationID}}      safeslop.invocation: {{yaml .InvocationID}}
{{end}}      safeslop.managed: "true"
{{end}}  egress:
    labels:
{{if .SessionID}}      safeslop.session: {{yaml .SessionID}}
{{end}}{{if .InvocationID}}      safeslop.invocation: {{yaml .InvocationID}}
{{end}}      safeslop.managed: "true"
    driver: bridge
