# syntax=docker/dockerfile:1
# safeslop agent image (specs/0058 N1): the golden base + the profile's RESOLVED package
# set, toggled by per-package ENABLE_<PKG> build args emitted from identity.go. Each
# package is a guarded RUN with a BuildKit cache mount. Steps are ordered so a package's
# requires install first (node before the npm CLIs that need npm) for EVERY enabled
# subset, satisfying the resolver's topological order with a fixed Dockerfile.
#
# Versions + per-arch digests are passed as build args (sourced from the in-tree catalog
# via identity.go), so the catalog is the single source of truth and a version/digest
# bump rotates the recipeID (correct cache invalidation). The 2-file base+agent split is
# kept for now; collapsing into one multi-stage Dockerfile is deferred (deviation from
# specs/0058 N1, noted).
ARG BASE=local/safeslop-base:latest
FROM ${BASE}

# Installs write to /usr/local (root); the base image's default user is the unprivileged
# `agent`. Switch to root for the build, then drop back to agent at the end.
USER root
ENV DEBIAN_FRONTEND=noninteractive

# --- node (kind: binary) — official multi-arch tarball, sha256-verified per arch.
# Provides npm, which the npm CLIs below require; installed FIRST so any subset that
# enables a CLI also has node. amd64 selects the x64 tarball.
ARG ENABLE_NODE=false
ARG NODE_VERSION=
ARG NODE_SHA256_AMD64=
ARG NODE_SHA256_ARM64=
RUN if [ "$ENABLE_NODE" = "true" ]; then set -eux; \
      # Node publishes .tar.xz archives. Keep xz as a guarded package-local build
      # helper (not in the universal base), so shell-only profiles stay lean.
      apt-get update; \
      apt-get install -y --no-install-recommends xz-utils; \
      arch="$(dpkg --print-architecture)"; \
      case "$arch" in \
        amd64) ntarch=x64;   sha="$NODE_SHA256_AMD64";; \
        arm64) ntarch=arm64; sha="$NODE_SHA256_ARM64";; \
        *) echo "node: unsupported build arch $arch" >&2; exit 1;; \
      esac; \
      curl -fsSLo /tmp/node.tar.xz \
        "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${ntarch}.tar.xz"; \
      echo "${sha}  /tmp/node.tar.xz" | sha256sum -c -; \
      tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 --no-same-owner; \
      rm -f /tmp/node.tar.xz; \
      apt-get purge -y --auto-remove xz-utils; \
      rm -rf /var/lib/apt/lists/*; \
      node --version; npm --version; \
    fi

# --- claude-code (kind: npm) — Claude Code CLI, exact version.
ARG ENABLE_CLAUDE_CODE=false
ARG CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code
ARG CLAUDE_CODE_VERSION=
RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    if [ "$ENABLE_CLAUDE_CODE" = "true" ]; then set -eux; \
      npm install -g "${CLAUDE_CODE_NPM_PACKAGE}@${CLAUDE_CODE_VERSION}"; \
    fi

# --- pi (kind: npm). --ignore-scripts: skip pi's npm lifecycle scripts (supply-chain
# hygiene; matches pi.dev's published install command).
ARG ENABLE_PI=false
ARG PI_NPM_PACKAGE=@earendil-works/pi-coding-agent
ARG PI_VERSION=
RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    if [ "$ENABLE_PI" = "true" ]; then set -eux; \
      npm install -g --ignore-scripts "${PI_NPM_PACKAGE}@${PI_VERSION}"; \
    fi

# --- pnpm (kind: npm) — JS/TS package manager, exact version.
ARG ENABLE_PNPM=false
ARG PNPM_NPM_PACKAGE=pnpm
ARG PNPM_VERSION=
RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    if [ "$ENABLE_PNPM" = "true" ]; then set -eux; \
      npm install -g "${PNPM_NPM_PACKAGE}@${PNPM_VERSION}"; \
    fi

# NOTE: bun, uv, mise, ripgrep, fd are in the catalog but ship the IW2 digest SENTINEL;
# the Go BuildReady gate (policy.BuildReadyFor) refuses to build a profile that resolves
# any of them, so no ENABLE_<PKG> for them is ever emitted here. They get real digests +
# their own guarded RUN blocks in a follow-up. python3 (kind: apt) likewise lands later.

USER agent
WORKDIR /workspace
CMD ["fish"]
