# Copy to library/layer/container/agent-tools.env and customize pinned versions.
#
# For unified isolation policy (sandbox-exec, docker-compose, envoy, ...),
# install `cue` (brew install cue-lang/tap/cue) and use `slop-isolate`.
# Presets ship for every tool below; see library/layer/policy/presets/.

# Enable npm CLIs only when you need them.
ENABLE_CLAUDE_CODE=false
ENABLE_PI=false

# Python stacks enabled by default.
ENABLE_CREWAI=true
ENABLE_PYDANTICAI=true
ENABLE_AG2=true

# Pin package coordinates for reproducible builds.
CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code
CLAUDE_CODE_VERSION=2.1.121


PI_NPM_PACKAGE=@earendil-works/pi-coding-agent
PI_VERSION=0.80.2

CREWAI_VERSION=0.11.2
PYDANTIC_AI_VERSION=1.87.0
PYDANTIC_AI_HARNESS_VERSION=0.2.0
AG2_VERSION=0.12.1

# OpenClaw / ZeroClaw — reserved slots.
# These tools are described in README "OpenClaw deep dive" and
# "ZeroClaw deep dive" and gated by library/task/restrictive-flows/openclaw.md
# and library/task/restrictive-flows/zeroclaw.md. Distribution method is
# upstream-specific; wire the install in Dockerfile.agent.tools when
# you enable them, and pin to an exact version (never `latest`).
# ENABLE_OPENCLAW=false
# OPENCLAW_VERSION=
# ENABLE_ZEROCLAW=false
# ZEROCLAW_VERSION=
