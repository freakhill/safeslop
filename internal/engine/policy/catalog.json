      "note": "apt kind — transitives are frozen by the golden-base Debian-snapshot pin (specs/0058 N2.2); reserved for what only apt provides",
      "version": "3.11"
    },
    {
      "buildFetch": [
        "github.com"
      ],
      "kind": "binary",
