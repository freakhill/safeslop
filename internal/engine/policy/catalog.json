      "sha256": {
        "amd64": "9749e988f437343b7fa832c69ded82a312e41a03116d766797ac14f6f9eee578",
        "arm64": "0294e8b915ab75f92c7513d2fcb830ae06e10684e6c603e99a87dbf8835389c1"
