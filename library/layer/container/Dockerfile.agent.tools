FROM local/agent-sandbox:latest

ARG ENABLE_CLAUDE_CODE=false
ARG ENABLE_OPENCODE=false
ARG ENABLE_PI=false
ARG ENABLE_CREWAI=true
ARG ENABLE_PYDANTICAI=true
ARG ENABLE_AG2=true

ARG CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code
ARG CLAUDE_CODE_VERSION=2.1.121
ARG OPENCODE_NPM_PACKAGE=opencode-ai
ARG OPENCODE_VERSION=1.14.28
ARG PI_NPM_PACKAGE=@earendil-works/pi-coding-agent
ARG PI_VERSION=0.80.2

ARG CREWAI_VERSION=0.11.2
ARG PYDANTIC_AI_VERSION=1.87.0
ARG PYDANTIC_AI_HARNESS_VERSION=0.2.0
ARG AG2_VERSION=0.12.1

# mise — pinned toolchain provisioner for `toolchain: {kind: "mise"}` (SP5).
ARG MISE_VERSION=2026.6.11

# Keep Python tooling current for framework installs.
# --break-system-packages: the base image is node:22-bookworm whose
# python3 ships with PEP 668 (externally-managed-environment). We're
# inside a single-purpose container so the "might break the OS"
# rationale for that gate doesn't apply. The flag matches what
# `uv pip install --system` does in the steps below.
RUN python3 -m pip install --no-cache-dir --break-system-packages --upgrade pip setuptools wheel

# Optional npm-based CLIs. These are disabled/enabled via build args.
RUN if [ "$ENABLE_CLAUDE_CODE" = "true" ]; then \
      npm install -g "${CLAUDE_CODE_NPM_PACKAGE}@${CLAUDE_CODE_VERSION}"; \
    fi

RUN if [ "$ENABLE_OPENCODE" = "true" ]; then \
      npm install -g "${OPENCODE_NPM_PACKAGE}@${OPENCODE_VERSION}"; \
    fi

# --ignore-scripts: skip Pi's npm lifecycle scripts (supply-chain hygiene; matches
# pi.dev's own published install command).
RUN if [ "$ENABLE_PI" = "true" ]; then \
      npm install -g --ignore-scripts "${PI_NPM_PACKAGE}@${PI_VERSION}"; \
    fi

# Optional Python agent stacks.
RUN if [ "$ENABLE_CREWAI" = "true" ]; then \
      uv pip install --system --break-system-packages --no-cache "crewai==${CREWAI_VERSION}"; \
    fi

RUN if [ "$ENABLE_PYDANTICAI" = "true" ]; then \
      uv pip install --system --break-system-packages --no-cache "pydantic-ai==${PYDANTIC_AI_VERSION}" "pydantic-ai-harness==${PYDANTIC_AI_HARNESS_VERSION}"; \
    fi

RUN if [ "$ENABLE_AG2" = "true" ]; then \
      uv pip install --system --break-system-packages --no-cache "ag2==${AG2_VERSION}"; \
    fi

# mise: a single static binary (arch-detected), pinned by MISE_VERSION. nix is intentionally
# NOT installed — the agent container runs read_only:true and nix needs a writable /nix store
# (a follow-up: nix-store volume + relaxed hardening). toolchain:nix in a container fails fast.
RUN arch="$(uname -m)"; case "$arch" in x86_64) a=x64;; aarch64|arm64) a=arm64;; *) a="$arch";; esac; \
    curl -fsSL "https://github.com/jdx/mise/releases/download/v${MISE_VERSION}/mise-v${MISE_VERSION}-linux-${a}" \
      -o /usr/local/bin/mise && chmod +x /usr/local/bin/mise && mise --version

WORKDIR /workspace
CMD ["fish"]
