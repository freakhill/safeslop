# syntax=docker/dockerfile:1@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89
# safeslop agent image: the golden base plus the profile's resolved package set.
# identity.go emits every ENABLE/version/artifact URL/digest argument from the reviewed
# catalog; changing any coordinate rotates the content-addressed recipe ID.
ARG BASE=local/safeslop-base:latest
FROM ${BASE}

LABEL safeslop.managed="true"
USER root
ENV DEBIAN_FRONTEND=noninteractive

# Node is explicit because npm packages require it and its .tar.xz needs a guarded build
# helper that is absent from the minimal base.
ARG ENABLE_NODE=false
ARG NODE_VERSION=
ARG NODE_URL_AMD64=
ARG NODE_URL_ARM64=
ARG NODE_SHA256_AMD64=
ARG NODE_SHA256_ARM64=
RUN if [ "$ENABLE_NODE" = "true" ]; then set -eux; \
      apt-get update; apt-get install -y --no-install-recommends xz-utils; \
      arch="$(dpkg --print-architecture)"; \
      case "$arch" in amd64) url="$NODE_URL_AMD64"; sha="$NODE_SHA256_AMD64";; arm64) url="$NODE_URL_ARM64"; sha="$NODE_SHA256_ARM64";; *) echo "node: unsupported build arch $arch" >&2; exit 1;; esac; \
      curl -fsSLo /tmp/node.tar.xz "$url"; echo "$sha  /tmp/node.tar.xz" | sha256sum -c -; \
      tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 --no-same-owner; \
      rm -f /tmp/node.tar.xz; apt-get purge -y --auto-remove xz-utils; rm -rf /var/lib/apt/lists/*; \
      node --version; npm --version; \
    fi

# Exact npm projects are selected into the otherwise private build context at
# npm-locks/claude-code, npm-locks/pi, or npm-locks/pnpm. npm ci verifies every
# transitive SRI. Package names, binary paths, and lifecycle policy are closed
# below; build arguments can only attest the Go-validated contract, not widen it.
# --- claude-code / pi / pnpm locked projects
ARG ENABLE_CLAUDE_CODE=false
ARG CLAUDE_CODE_VERSION=
ARG CLAUDE_CODE_NPM_LOCK_SHA256=
ARG CLAUDE_CODE_NPM_BINARY=
ARG CLAUDE_CODE_NPM_SCRIPT_POLICY=

ARG ENABLE_PI=false
ARG PI_VERSION=
ARG PI_NPM_LOCK_SHA256=
ARG PI_NPM_BINARY=
ARG PI_NPM_SCRIPT_POLICY=

ARG ENABLE_PNPM=false
ARG PNPM_VERSION=
ARG PNPM_NPM_LOCK_SHA256=
ARG PNPM_NPM_BINARY=
ARG PNPM_NPM_SCRIPT_POLICY=

RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    --mount=type=bind,source=npm-locks,target=/run/safeslop-npm-locks,readonly <<'EOF'
set -eu
lock_hash() {
  { cat "$1/package.json"; printf '\0'; cat "$1/package-lock.json"; } | sha256sum | awk '{print $1}'
}
install_locked_npm() {
  name=$1
  expected_hash=$2
  package_name=$3
  version=$4
  package_path=$5
  binary=$6
  binary_path=$7
  script_policy=$8
  source="/run/safeslop-npm-locks/$name"
  destination="/opt/safeslop/npm/$name"
  test -f "$source/package.json" -a -f "$source/package-lock.json"
  test "$(lock_hash "$source")" = "$expected_hash"
  test "$(node -e 'const p=require(process.argv[1]); process.stdout.write(p.dependencies[process.argv[2]] || "")' "$source/package.json" "$package_name")" = "$version"
  install -d -m 0755 "$destination"
  cp "$source/package.json" "$source/package-lock.json" "$destination/"
  cd "$destination"
  case "$script_policy" in
    ignore-scripts)
      npm ci --omit=dev --ignore-scripts --no-audit --no-fund
      ;;
    reviewed-root-postinstall)
      npm ci --omit=dev --no-audit --no-fund
      ;;
    *)
      echo "$name: unreviewed npm lifecycle policy" >&2
      exit 1
      ;;
  esac
  test -x "$destination/node_modules/$package_path/$binary_path"
  ln -sfn "$destination/node_modules/$package_path/$binary_path" "/usr/local/bin/$binary"
}
if [ "$ENABLE_CLAUDE_CODE" = true ]; then
  test "$CLAUDE_CODE_NPM_BINARY" = claude
  test "$CLAUDE_CODE_NPM_SCRIPT_POLICY" = reviewed-root-postinstall
  install_locked_npm claude-code "$CLAUDE_CODE_NPM_LOCK_SHA256" @anthropic-ai/claude-code "$CLAUDE_CODE_VERSION" @anthropic-ai/claude-code claude bin/claude.exe "$CLAUDE_CODE_NPM_SCRIPT_POLICY"
fi
if [ "$ENABLE_PI" = true ]; then
  test "$PI_NPM_BINARY" = pi
  test "$PI_NPM_SCRIPT_POLICY" = ignore-scripts
  install_locked_npm pi "$PI_NPM_LOCK_SHA256" @earendil-works/pi-coding-agent "$PI_VERSION" @earendil-works/pi-coding-agent pi dist/cli.js "$PI_NPM_SCRIPT_POLICY"
fi
if [ "$ENABLE_PNPM" = true ]; then
  test "$PNPM_NPM_BINARY" = pnpm
  test "$PNPM_NPM_SCRIPT_POLICY" = ignore-scripts
  install_locked_npm pnpm "$PNPM_NPM_LOCK_SHA256" pnpm "$PNPM_VERSION" pnpm pnpm bin/pnpm.cjs "$PNPM_NPM_SCRIPT_POLICY"
  ln -sfn /opt/safeslop/npm/pnpm/node_modules/pnpm/bin/pnpx.cjs /usr/local/bin/pnpx
fi
EOF

# python3 is an exact leaf from the immutable, signed Debian snapshot inherited from
# Dockerfile.agent; the snapshot also freezes all transitive selection.
ARG ENABLE_PYTHON3=false
ARG PYTHON3_VERSION=
RUN if [ "$ENABLE_PYTHON3" = "true" ]; then set -eux; \
      apt-get update; apt-get install -y --no-install-recommends "python3=${PYTHON3_VERSION}"; \
      rm -rf /var/lib/apt/lists/*; python3 --version; \
    fi

# Shared build-only primitive for the explicit binary handlers below. Every invocation
# downloads exactly one catalog URL, verifies its architecture-specific SHA256 before
# extraction, and installs only the named executable(s). It is removed before runtime.
RUN <<'EOF'
set -eu
cat >/usr/local/sbin/install-catalog-artifact <<'SCRIPT'
#!/bin/sh
set -eu
label=$1
url=$2
sha=$3
format=$4
shift 4
archive="/tmp/${label}.artifact"
work="$(mktemp -d "/tmp/${label}.XXXXXX")"
trap 'rm -rf "$archive" "$work"' EXIT
curl -fsSLo "$archive" "$url"
echo "$sha  $archive" | sha256sum -c -
case "$format" in
  direct)
    install -m 0755 "$archive" "/usr/local/bin/$1"
    ;;
  tgz)
    tar -xzf "$archive" -C "$work" --no-same-owner
    for binary in "$@"; do
      source="$(find "$work" -type f -name "$binary" -print -quit)"
      test -n "$source"
      install -m 0755 "$source" "/usr/local/bin/$binary"
    done
    ;;
  go)
    rm -rf /usr/local/go
    tar -xzf "$archive" -C /usr/local --no-same-owner
    ;;
  rust)
    tar -xJf "$archive" -C "$work" --no-same-owner
    installer="$(find "$work" -type f -name install.sh -print -quit)"
    test -n "$installer"
    sh "$installer" --prefix=/usr/local --disable-ldconfig
    ;;
  *)
    echo "$label: unsupported artifact format $format" >&2
    exit 1
    ;;
esac
SCRIPT
chmod 0755 /usr/local/sbin/install-catalog-artifact
EOF

# Each package has its own guarded handler so no resolved package can be silently
# omitted. URL and digest selection fails closed on unsupported architectures.

# --- ripgrep
ARG ENABLE_RIPGREP=false
ARG RIPGREP_VERSION=
ARG RIPGREP_URL_AMD64=
ARG RIPGREP_URL_ARM64=
ARG RIPGREP_SHA256_AMD64=
ARG RIPGREP_SHA256_ARM64=
RUN if [ "$ENABLE_RIPGREP" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$RIPGREP_URL_AMD64"; sha="$RIPGREP_SHA256_AMD64";; arm64) url="$RIPGREP_URL_ARM64"; sha="$RIPGREP_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact ripgrep "$url" "$sha" tgz rg; rg --version; fi

# --- fd
ARG ENABLE_FD=false
ARG FD_VERSION=
ARG FD_URL_AMD64=
ARG FD_URL_ARM64=
ARG FD_SHA256_AMD64=
ARG FD_SHA256_ARM64=
RUN if [ "$ENABLE_FD" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$FD_URL_AMD64"; sha="$FD_SHA256_AMD64";; arm64) url="$FD_URL_ARM64"; sha="$FD_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact fd "$url" "$sha" tgz fd; fd --version; fi

# --- bat
ARG ENABLE_BAT=false
ARG BAT_VERSION=
ARG BAT_URL_AMD64=
ARG BAT_URL_ARM64=
ARG BAT_SHA256_AMD64=
ARG BAT_SHA256_ARM64=
RUN if [ "$ENABLE_BAT" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$BAT_URL_AMD64"; sha="$BAT_SHA256_AMD64";; arm64) url="$BAT_URL_ARM64"; sha="$BAT_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact bat "$url" "$sha" tgz bat; bat --version; fi

# --- eza
ARG ENABLE_EZA=false
ARG EZA_VERSION=
ARG EZA_URL_AMD64=
ARG EZA_URL_ARM64=
ARG EZA_SHA256_AMD64=
ARG EZA_SHA256_ARM64=
RUN if [ "$ENABLE_EZA" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$EZA_URL_AMD64"; sha="$EZA_SHA256_AMD64";; arm64) url="$EZA_URL_ARM64"; sha="$EZA_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact eza "$url" "$sha" tgz eza; eza --version; fi

# --- fzf
ARG ENABLE_FZF=false
ARG FZF_VERSION=
ARG FZF_URL_AMD64=
ARG FZF_URL_ARM64=
ARG FZF_SHA256_AMD64=
ARG FZF_SHA256_ARM64=
RUN if [ "$ENABLE_FZF" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$FZF_URL_AMD64"; sha="$FZF_SHA256_AMD64";; arm64) url="$FZF_URL_ARM64"; sha="$FZF_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact fzf "$url" "$sha" tgz fzf; fzf --version; fi

# --- zoxide
ARG ENABLE_ZOXIDE=false
ARG ZOXIDE_VERSION=
ARG ZOXIDE_URL_AMD64=
ARG ZOXIDE_URL_ARM64=
ARG ZOXIDE_SHA256_AMD64=
ARG ZOXIDE_SHA256_ARM64=
RUN if [ "$ENABLE_ZOXIDE" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$ZOXIDE_URL_AMD64"; sha="$ZOXIDE_SHA256_AMD64";; arm64) url="$ZOXIDE_URL_ARM64"; sha="$ZOXIDE_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact zoxide "$url" "$sha" tgz zoxide; zoxide --version; fi

# --- yq (direct executable)
ARG ENABLE_YQ=false
ARG YQ_VERSION=
ARG YQ_URL_AMD64=
ARG YQ_URL_ARM64=
ARG YQ_SHA256_AMD64=
ARG YQ_SHA256_ARM64=
RUN if [ "$ENABLE_YQ" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$YQ_URL_AMD64"; sha="$YQ_SHA256_AMD64";; arm64) url="$YQ_URL_ARM64"; sha="$YQ_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact yq "$url" "$sha" direct yq; yq --version; fi

# --- uv (archive contains uv and uvx)
ARG ENABLE_UV=false
ARG UV_VERSION=
ARG UV_URL_AMD64=
ARG UV_URL_ARM64=
ARG UV_SHA256_AMD64=
ARG UV_SHA256_ARM64=
RUN if [ "$ENABLE_UV" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$UV_URL_AMD64"; sha="$UV_SHA256_AMD64";; arm64) url="$UV_URL_ARM64"; sha="$UV_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact uv "$url" "$sha" tgz uv uvx; uv --version; fi

# --- ruff
ARG ENABLE_RUFF=false
ARG RUFF_VERSION=
ARG RUFF_URL_AMD64=
ARG RUFF_URL_ARM64=
ARG RUFF_SHA256_AMD64=
ARG RUFF_SHA256_ARM64=
RUN if [ "$ENABLE_RUFF" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$RUFF_URL_AMD64"; sha="$RUFF_SHA256_AMD64";; arm64) url="$RUFF_URL_ARM64"; sha="$RUFF_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact ruff "$url" "$sha" tgz ruff; ruff --version; fi

# --- Go toolchain
ARG ENABLE_GO=false
ARG GO_VERSION=
ARG GO_URL_AMD64=
ARG GO_URL_ARM64=
ARG GO_SHA256_AMD64=
ARG GO_SHA256_ARM64=
RUN if [ "$ENABLE_GO" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$GO_URL_AMD64"; sha="$GO_SHA256_AMD64";; arm64) url="$GO_URL_ARM64"; sha="$GO_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact go "$url" "$sha" go; /usr/local/go/bin/go version; fi
ENV PATH="/usr/local/go/bin:${PATH}"

# --- Rust rustc+cargo toolchain
ARG ENABLE_RUST=false
ARG RUST_VERSION=
ARG RUST_URL_AMD64=
ARG RUST_URL_ARM64=
ARG RUST_SHA256_AMD64=
ARG RUST_SHA256_ARM64=
RUN if [ "$ENABLE_RUST" = "true" ]; then set -eux; apt-get update; apt-get install -y --no-install-recommends xz-utils; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$RUST_URL_AMD64"; sha="$RUST_SHA256_AMD64";; arm64) url="$RUST_URL_ARM64"; sha="$RUST_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact rust "$url" "$sha" rust; apt-get purge -y --auto-remove xz-utils; rm -rf /var/lib/apt/lists/*; rustc --version; cargo --version; fi

# --- hyperfine
ARG ENABLE_HYPERFINE=false
ARG HYPERFINE_VERSION=
ARG HYPERFINE_URL_AMD64=
ARG HYPERFINE_URL_ARM64=
ARG HYPERFINE_SHA256_AMD64=
ARG HYPERFINE_SHA256_ARM64=
RUN if [ "$ENABLE_HYPERFINE" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$HYPERFINE_URL_AMD64"; sha="$HYPERFINE_SHA256_AMD64";; arm64) url="$HYPERFINE_URL_ARM64"; sha="$HYPERFINE_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact hyperfine "$url" "$sha" tgz hyperfine; hyperfine --version; fi

# --- tokei
ARG ENABLE_TOKEI=false
ARG TOKEI_VERSION=
ARG TOKEI_URL_AMD64=
ARG TOKEI_URL_ARM64=
ARG TOKEI_SHA256_AMD64=
ARG TOKEI_SHA256_ARM64=
RUN if [ "$ENABLE_TOKEI" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$TOKEI_URL_AMD64"; sha="$TOKEI_SHA256_AMD64";; arm64) url="$TOKEI_URL_ARM64"; sha="$TOKEI_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact tokei "$url" "$sha" tgz tokei; tokei --version; fi

# --- sccache
ARG ENABLE_SCCACHE=false
ARG SCCACHE_VERSION=
ARG SCCACHE_URL_AMD64=
ARG SCCACHE_URL_ARM64=
ARG SCCACHE_SHA256_AMD64=
ARG SCCACHE_SHA256_ARM64=
RUN if [ "$ENABLE_SCCACHE" = "true" ]; then set -eux; arch="$(dpkg --print-architecture)"; case "$arch" in amd64) url="$SCCACHE_URL_AMD64"; sha="$SCCACHE_SHA256_AMD64";; arm64) url="$SCCACHE_URL_ARM64"; sha="$SCCACHE_SHA256_ARM64";; *) exit 1;; esac; install-catalog-artifact sccache "$url" "$sha" tgz sccache; sccache --version; fi

# Other catalog packages, including mise, remain fail-closed until separately pinned
# and wired; identity.go's allowlist prevents their silent omission.
RUN rm -f /usr/local/sbin/install-catalog-artifact
USER agent
WORKDIR /workspace
CMD ["fish"]
