# Reference for Dockerfile.agent.tools build args (specs/0058 N1).
#
# safeslop no longer reads this file at build time: the engine derives the agent
# image's build args from the profile's RESOLVED catalog package set (see
# internal/engine/container/identity.go -> toolsBuildArgs). The catalog
# (internal/engine/policy/catalog.go) is the single source of truth for versions and
# per-arch digests. This file documents the arg shape for humans + tooling only.

# BASE is the golden-base image tag (local/safeslop-base:<recipeID>), threaded in by the
# engine so a base change rotates the agent recipeID.
# BASE=local/safeslop-base:<id>

# Per-package toggles: ENABLE_<PKG>=true is emitted only for packages the profile
# resolved. The engine never sets these by hand (the old hardcoded
# ENABLE_CLAUDE_CODE/ENABLE_PI=true is gone).
ENABLE_NODE=false
ENABLE_CLAUDE_CODE=false
ENABLE_PI=false
ENABLE_PNPM=false
ENABLE_PYTHON3=false
ENABLE_RIPGREP=false
ENABLE_FD=false
ENABLE_BAT=false
ENABLE_EZA=false
ENABLE_FZF=false
ENABLE_ZOXIDE=false
ENABLE_YQ=false
ENABLE_UV=false
ENABLE_RUFF=false
ENABLE_GO=false
ENABLE_RUST=false
ENABLE_HYPERFINE=false
ENABLE_TOKEI=false
ENABLE_SCCACHE=false

# Pinned coordinates, emitted alongside each enabled package (values come from the
# catalog; shown here as the v1 pins for reference).
NODE_VERSION=22.23.1
# node is a multi-arch binary: per-arch sha256, selected by `dpkg --print-architecture`.
NODE_SHA256_AMD64=9749e988f437343b7fa832c69ded82a312e41a03116d766797ac14f6f9eee578
NODE_SHA256_ARM64=0294e8b915ab75f92c7513d2fcb830ae06e10684e6c603e99a87dbf8835389c1

CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code
CLAUDE_CODE_VERSION=2.1.121

PI_NPM_PACKAGE=@earendil-works/pi-coding-agent
PI_VERSION=0.80.2

PNPM_NPM_PACKAGE=pnpm
PNPM_VERSION=9.15.0

# Every binary package also emits per-arch URL and SHA256 args from the catalog (for
# example NODE_URL_AMD64 and NODE_SHA256_AMD64). The Dockerfile verifies the selected
# digest before extraction. Catalog packages outside the explicit image allowlist (for
# example bun and mise) remain fail-closed until separately pinned and wired.
