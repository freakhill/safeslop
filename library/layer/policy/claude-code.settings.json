{
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "./",
        "./tmp"
      ],
      "denyRead": [
        "~/.ssh/**",
        "~/.aws/**",
        "~/.config/gcloud/**",
        "~/.gnupg/**",
        "~/.npmrc",
        "~/.pypirc"
      ],
      "denyWrite": [
        "~/**",
        "/etc/**",
        "/private/**"
      ]
    },
    "network": {
      "allowDomains": [
        "github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    }
  }
}
