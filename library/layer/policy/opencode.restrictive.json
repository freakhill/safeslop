{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "**/.env*": "deny",
      "**/.ssh/**": "deny",
      "**/.aws/**": "deny",
      "**/.config/gcloud/**": "deny"
    },
    "edit": "ask",
    "external_directory": "deny",
    "webfetch": "ask",
    "websearch": "ask",
    "bash": {
      "*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm ci --ignore-scripts*": "allow",
      "uv sync --frozen*": "allow",
      "uv pip install --only-binary :all:*": "allow"
    }
  }
}
